# Application
APP_NAME=Watch Party
ENVIRONMENT=development
DEBUG=true
SQL_ECHO=false

# Security (generate a secure random key for production)
SECRET_KEY=your-super-secret-key-change-in-production

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://watchparty:watchparty_dev@localhost:5432/watchparty_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Room Settings
MAX_ROOM_PARTICIPANTS=6
ROOM_TIMEOUT_HOURS=4
